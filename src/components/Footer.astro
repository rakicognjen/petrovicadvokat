---
const year = new Date().getFullYear();

const gradjanskoGroup = {
  hub: { href: '/gradjansko-pravo/', label: 'Građansko pravo' },
  items: [
    { href: '/gradjansko-pravo/razvod-braka-cukarica', label: 'Razvod braka' },
    { href: '/gradjansko-pravo/nekretnine-cukarica', label: 'Nekretnine' },
    { href: '/gradjansko-pravo/naknada-stete-beograd', label: 'Naknada štete' },
    { href: '/gradjansko-pravo/nasledno-pravo-beograd', label: 'Nasledno pravo' },
    { href: '/gradjansko-pravo/smetanje-poseda-cukarica', label: 'Smetanje poseda' },
    { href: '/gradjansko-pravo/medjunarodni-razvod-beograd', label: 'Međunarodni razvod' },
  ],
};

const krivicnoGroup = {
  hub: { href: '/krivicno-pravo/', label: 'Krivično pravo' },
  items: [
    { href: '/krivicno-pravo/krivicna-odbrana-beograd', label: 'Odbrana u krivičnom postupku' },
    { href: '/krivicno-pravo/saobracajni-prekrsaji-beograd', label: 'Saobraćajni prekršaji' },
  ],
};

const upravnoGroup = {
  hub: { href: '/upravno-pravo/', label: 'Upravno pravo' },
  items: [
    { href: '/upravno-pravo/upravni-sporovi-beograd', label: 'Upravni sporovi' },
  ],
};
---

<footer>
  <div class="footer-top">
    <div>
      <div class="footer-brand">Marko A. Petrović</div>
      <p class="footer-desc">Advokatska kancelarija u Beogradu, specijalizovana za građansko, upravno i krivično pravo. Zastupanje pred sudovima i organima uprave, pravni saveti i sastavljanje pravnih akata.</p>
      <a class="btn-brick" style="font-size:10px; padding:10px 22px;" href="/kontakt">Zakažite konsultaciju</a>
    </div>
    <div>
      <div class="footer-col-title">Navigacija</div>
      <ul class="footer-links">
        <li><a href="/o-advokatu">O advokatu</a></li>
        <li><a href="/kontakt">Kontakt</a></li>
      </ul>
    </div>
    <div>
      <div class="footer-col-title"><a href={gradjanskoGroup.hub.href}>{gradjanskoGroup.hub.label}</a></div>
      <ul class="footer-links">
        {gradjanskoGroup.items.map(item => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <div class="footer-col-title"><a href={krivicnoGroup.hub.href}>{krivicnoGroup.hub.label}</a></div>
      <ul class="footer-links">
        {krivicnoGroup.items.map(item => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
      <div class="footer-col-title footer-col-title-secondary"><a href={upravnoGroup.hub.href}>{upravnoGroup.hub.label}</a></div>
      <ul class="footer-links">
        {upravnoGroup.items.map(item => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <div class="footer-col-title">Kontakt</div>
      <a href="tel:0628226111" class="footer-ci">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2"/></svg>
        062/822-6-111
      </a>
      <a href="mailto:mpetrovic694@gmail.com" class="footer-ci">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"/><path d="M3 7l9 6l9 -6"/></svg>
        mpetrovic694@gmail.com
      </a>
      <div class="footer-ci">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M9 11a3 3 0 1 0 6 0a3 3 0 0 0 -6 0"/><path d="M17.657 16.657l-4.243 4.243a2 2 0 0 1 -2.827 0l-4.244 -4.243a8 8 0 1 1 11.314 0"/></svg>
        Ul. Frontovska 24, 11030 Beograd
      </div>
    </div>
  </div>
  <div class="footer-bar">
    <span>© {year} Marko A. Petrović, advokat · Sva prava zadržana</span>
    <span>Advokatska kancelarija Beograd</span>
  </div>
</footer>
