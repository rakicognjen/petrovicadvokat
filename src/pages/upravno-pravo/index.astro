---
import BaseLayout from '../../layouts/BaseLayout.astro';

const usluge = [
  { h: 'Upravni sporovi', p: 'Žalbe na rešenja Poreske uprave i Katastra, tužbe Upravnom sudu, PIO fond.', href: '/upravno-pravo/upravni-sporovi-beograd' },
];

const faq = [
  {
    question: 'Koji je opšti rok za žalbu na rešenje državnog organa?',
    answer: 'Rokovi zavise od vrste postupka i konkretnog organa, ali su po pravilu kratki i prekluzivni (najčešće 15 do 30 dana od dostavljanja rešenja) — zbog toga je bitno da se odluka proveri kod advokata odmah po prijemu, a ne tek kada rok istekne.',
  },
  {
    question: 'Da li mogu da se žalim ako državni organ uopšte ne odgovara na moj zahtev?',
    answer: "Da — takozvano 'ćutanje administracije' takođe predstavlja osnov za pravnu reakciju, uključujući požurnicu i, po potrebi, tužbu Upravnom sudu zbog nedonošenja akta.",
  },
  {
    question: 'Da li se ovi postupci uvek završavaju na sudu, ili ima i vansudskih rešenja?',
    answer: 'Veliki broj predmeta rešava se već u drugostepenom upravnom postupku (žalba višem organu), bez potrebe za tužbom sudu. Tužba Upravnom sudu je krajnja instanca kada su redovni pravni lekovi pred samom administracijom iscrpljeni.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Početna', item: `${Astro.site}` },
    { '@type': 'ListItem', position: 2, name: 'Upravno pravo', item: `${Astro.site}upravno-pravo/` },
  ],
};
---

<BaseLayout
  title="Advokat za upravno pravo Beograd | Marko A. Petrović"
  description="Advokat za upravne sporove u Beogradu — žalbe na rešenja državnih organa i tužbe Upravnom sudu. Niska konkurencija, brza pravna zaštita od države."
>
  <section class="page-hero">
    <div class="page-hero-inner">
      <div class="page-hero-kicker">Upravno pravo</div>
      <h1 class="page-hero-h">Advokat za upravno pravo – Beograd</h1>
      <p class="page-hero-deck">Žalbe na rešenja državnih organa i tužbe Upravnom sudu — pravna zaštita kada je suprotna strana u sporu sama država.</p>
    </div>
  </section>

  <section class="page-body">
    <div class="wrap content-grid">
      <article class="content-section">
        <p>Upravno pravo reguliše odnos građanina i pravnih lica prema državi — od poreskih rešenja, preko Katastra, do građevinskih dozvola i inspekcijskih postupaka. Ova oblast je znatno manje zastupljena kod advokata u Srbiji nego građansko ili krivično pravo, što našoj kancelariji omogućava da klijentima pruži fokusiranu, specijalizovanu podršku u sporovima protiv državnih organa i javnih preduzeća.</p>
      </article>

      <article class="content-section">
        <h2>Kada vam je potreban advokat za upravno pravo</h2>
        <p>Upravni spor pokreće se kada građanin ili firma smatra da je državni organ doneo nezakonito, nepravilno ili nepravedno rešenje — bilo da se radi o odbijenom zahtevu za građevinsku dozvolu, pogrešnom poreskom rešenju, odbijenoj uknjižbi u Katastru ili rešenju inspekcije. Za razliku od građanskih sporova, ovde je suprotna strana država, što nosi posebna procesna pravila i strogo ograničene rokove — propuštanje roka za žalbu ili tužbu često trajno onemogućava dalju pravnu zaštitu.</p>
        <p>Zato je u ovim predmetima ključno na vreme prepoznati da je odluka državnog organa sporna i blagovremeno reagovati, umesto da se čeka da postupak sam od sebe krene u povoljnijem pravcu.</p>
      </article>

      <article class="content-section service-note">
        <h2>Zašto je ova oblast prilika za brzu i efikasnu zaštitu</h2>
        <p>Konkurencija među advokatima specijalizovanim za upravno pravo znatno je manja nego u građanskom ili krivičnom pravu, iako se sa problemima državne administracije — poreska rešenja, Katastar, građevinske dozvole — svakodnevno susreće veliki broj građana i firmi u Beogradu. To znači da klijenti koji potraže specijalizovanu pomoć u ovoj oblasti često dobijaju brže i preciznije vođenje predmeta nego u opterećenijim granama prava.</p>
      </article>

      <article class="content-section">
        <h2>Tipični primeri upravnih sporova</h2>
        <p>U praksi se upravni sporovi najčešće javljaju u nekoliko ponavljajućih situacija: odbijen zahtev za građevinsku dozvolu ili lokacijske uslove, sporno poresko rešenje o utvrđivanju poreza na imovinu ili poreza na prenos apsolutnih prava, odbijen zahtev za uknjižbu u Katastru nepokretnosti, kao i rešenja inspekcijskih organa (građevinske, tržišne, radne inspekcije) koja nameću mere ili kazne. U svim ovim slučajevima postupak počinje žalbom drugostepenom organu, a tek ukoliko ni ona ne da rezultat, sledi tužba Upravnom sudu Republike Srbije u Beogradu.</p>
        <p>Poseban i često zanemaren segment upravnog prava tiče se penzijskih i socijalnih prava — nepriznavanja radnog staža, pogrešnog obračuna penzije ili odbijanja zahteva za invalidsku penziju od strane PIO fonda — gde je pravovremena žalba jednako važna kao i kod imovinskih predmeta.</p>
      </article>
    </div>
  </section>

  <section class="hub-services-section">
    <div class="wrap">
      <div class="section-header">
        <div><span class="section-h-label">Pod-oblasti</span> <span class="section-h">Usluge u okviru upravnog prava</span></div>
      </div>
      <div class="hub-services-grid">
        {usluge.map((u) => (
          <a class="hub-service-cell" href={u.href}>
            <div class="hub-service-h">{u.h}</div>
            <div class="hub-service-rule"></div>
            <p class="hub-service-p">{u.p}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="wrap">
      <div class="section-header">
        <div><span class="section-h-label">FAQ</span> <span class="section-h">Često postavljana pitanja</span></div>
      </div>
      <div class="faq-grid">
        {faq.map((item) => (
          <article class="faq-item reveal">
            <h3 class="faq-question">{item.question}</h3>
            <p class="faq-answer">{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="page-cta-section">
    <div class="wrap page-cta-inner reveal">
      <div class="cta-copy">
        <div class="section-h-label">Pravna zaštita</div>
        <h2 class="section-h">Osporite nezakonitu odluku državnog organa</h2>
        <p>Državni organ je doneo odluku na vašu štetu? Zakažite konsultacije i proverite da li se ta odluka može pravno osporiti.</p>
      </div>
      <a class="btn-brick" href="/kontakt">Kontaktirajte nas</a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
