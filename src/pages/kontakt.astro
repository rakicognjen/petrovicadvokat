---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kontakt | Advokat Marko A. Petrović, Beograd"
  description="Kontaktirajte advokata Marka A. Petrovića u Beogradu. Adresa, telefon, email i termini za zakazivanje i prijem stranaka."
>
  <section class="page-hero">
    <div class="page-hero-inner">
      <div class="page-hero-kicker">Kontakt</div>
      <h1 class="page-hero-h">Zakažite konsultaciju</h1>
      <p class="page-hero-deck">Opišite vaš slučaj i pošaljite upit. Javićemo Vam se u najkraćem mogućem roku.</p>
      <div class="page-hero-cta">
        <div class="cta-strip cta-strip-dark">
          <span class="inline-cta-hint">Za hitne slučajeve:</span>
          <a class="cta-strip-phone" href="tel:0628226111">Pozovite nas: 062/822-6-111</a>
        </div>
      </div>
    </div>
  </section>

  <section class="kontakt-section">
    <div class="kontakt-inner wrap">
      <div class="kontakt-left reveal">
        <h2 class="kontakt-h">Podaci za kontakt</h2>
        <div class="kontakt-items">
          <div class="kontakt-item"><div class="kontakt-lbl">Telefon</div><div class="kontakt-val"><a href="tel:0628226111">062/822-6-111</a></div></div>
          <div class="kontakt-item"><div class="kontakt-lbl">Email</div><div class="kontakt-val"><a href="mailto:mpetrovic694@gmail.com">mpetrovic694@gmail.com</a></div></div>
          <div class="kontakt-item"><div class="kontakt-lbl">Adresa</div><div class="kontakt-val">Ul. Frontovska, Beograd</div></div>
          <div class="kontakt-item"><div class="kontakt-lbl">Zakazivanje i prijem stranaka</div><div class="kontakt-val">Pon – Pet: 15:00 – 19:00</div></div>
        </div>
        <a class="btn-brick" style="margin-top:28px;" href="https://www.google.com/maps/search/?api=1&query=Ul.+Frontovska+Beograd" target="_blank" rel="noopener">Otvorite mapu →</a>
      </div>
      <div class="kontakt-right reveal d2">
        <h2 class="kontakt-h" style="color:var(--cream); font-size:clamp(22px,3vw,32px);">Pošaljite upit</h2>
        <form id="contact-form" name="contact" method="POST" data-netlify="true" data-netlify-honeypot="bot-field" class="kontakt-form">
          <input type="hidden" name="form-name" value="contact" />
          <p class="k-honeypot" hidden>
            <label>Ne popunjavajte ovo polje: <input name="bot-field" /></label>
          </p>
          <label class="k-field">
            <span>Ime i prezime *</span>
            <input type="text" name="name" required />
          </label>
          <label class="k-field">
            <span>Email</span>
            <input type="email" name="email" />
          </label>
          <label class="k-field">
            <span>Telefon *</span>
            <input type="tel" name="phone" required />
          </label>
          <label class="k-field">
            <span>Vaša poruka *</span>
            <textarea name="message" rows="5" required></textarea>
          </label>
          <button type="submit" class="btn-brick">Pošalji upit →</button>
          <p class="k-required-note">* obavezno polje</p>
          <p id="form-status" class="k-status" role="status" aria-live="polite" hidden></p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status');
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  function encodeFormData(formData: FormData) {
    const params = new URLSearchParams();
    formData.forEach((value, key) => params.append(key, String(value)));
    return params.toString();
  }

  function setStatus(text: string, variant: 'success' | 'error') {
    if (!status) return;
    status.hidden = false;
    status.textContent = text;
    status.className = `k-status k-status-${variant}`;
  }

  form?.addEventListener('submit', (e) => {
    e.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = new FormData(form);

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Slanje...';
    }

    fetch('/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: encodeFormData(data),
    })
      .then((res) => {
        if (!res.ok) throw new Error('Slanje nije uspelo');
        form.reset();
        setStatus('Poruka je uspešno poslata. Javićemo Vam se u najkraćem mogućem roku.', 'success');
      })
      .catch(() => {
        setStatus('Slanje nije uspelo. Pozovite nas na 062/822-6-111 ili pišite na mpetrovic694@gmail.com.', 'error');
      })
      .finally(() => {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Pošalji upit →';
        }
      });
  });
</script>

<style>
  .kontakt-section { border-bottom: 3px solid var(--dark); }
  .kontakt-inner { display: grid; grid-template-columns: 1fr 1fr; }
  .kontakt-left { padding: 64px; border-right: 1px solid var(--tan); }
  .kontakt-h { font-family: var(--serif); font-size: clamp(24px, 3.5vw, 36px); margin-bottom: 32px; }
  .kontakt-items { display: flex; flex-direction: column; }
  .kontakt-item { display: flex; gap: 0; border-bottom: 1px solid var(--tan); padding: 18px 0; }
  .kontakt-item:first-child { border-top: 1px solid var(--tan); }
  .kontakt-lbl { font-size: 9px; font-weight: 800; letter-spacing: 3px; text-transform: uppercase; color: var(--brick); width: 110px; flex-shrink: 0; padding-top: 2px; }
  .kontakt-val { font-family: var(--serif); font-size: 16px; color: var(--dark); }
  .kontakt-val a { text-decoration: none; color: var(--dark); }
  .kontakt-val a:hover { color: var(--brick); }
  .kontakt-right { padding: 56px 64px; background: var(--dark); display: flex; flex-direction: column; gap: 20px; justify-content: center; }
  .kontakt-form { display: flex; flex-direction: column; gap: 16px; }
  .k-field { display: flex; flex-direction: column; gap: 6px; font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: rgba(253,248,240,0.5); font-weight: 600; }
  .k-field input, .k-field textarea { font-family: var(--sans); font-size: 14px; color: var(--dark); background: var(--cream); border: none; padding: 12px 14px; resize: vertical; }
  .k-field input:focus, .k-field textarea:focus { outline: 2px solid var(--brick3); outline-offset: 0; }
  .k-status { font-size: 13px; line-height: 1.6; padding: 12px 14px; margin: 0; }
  .k-status-success { background: rgba(120,160,110,0.15); color: #cfe7c8; }
  .k-status-error { background: rgba(180,70,60,0.18); color: #f3c8c3; }
  .k-required-note { font-size: 11px; color: rgba(253,248,240,0.4); margin: -6px 0 0; }
  @media (max-width: 900px) { .kontakt-inner { grid-template-columns: 1fr; } .kontakt-left { padding: 44px 24px; border-right: none; } .kontakt-right { padding: 44px 24px; } }
</style>
