import AreaLayout from '../../layouts/AreaLayout.astro';
---

<AreaLayout
  seoTitle="Advokat za upravno pravo Beograd — Marko A. Petrović"
  seoDescription="Advokat za upravno pravo u Beogradu — žalbe na rešenja upravnih organa, upravni sporovi i zastupanje pred organima uprave. Zakažite konsultaciju."
  pageTitle="Upravno pravo"
  deck="Žalbe na rešenja upravnih organa, pokretanje upravnog spora i zastupanje pred organima uprave, inspekcijama i lokalnom samoupravom."
>
  <section class="area-section">
    <div class="wrap area-grid">
      <div class="area-body reveal">
        <h2>Žalbe na rešenja upravnih organa</h2>
        <p>Kada organ uprave donese rešenje kojim stranka nije zadovoljna — u postupcima građevinske, imovinske, inspekcijske ili druge upravne materije — na raspolaganju je žalba drugostepenom organu, u zakonom propisanom roku. Advokat priprema žalbu tako da ukaže na sve pravne i činjenične nedostatke prvostepenog rešenja.</p>
        <p>Ukoliko drugostepeni organ ne postupi u zakonskom roku, ili žalba bude odbijena, stranka ima mogućnost da pokrene upravni spor pred Upravnim sudom.</p>

        <h2>Upravni spor</h2>
        <p>Upravni spor pokreće se tužbom protiv konačnog upravnog akta, kada stranka smatra da je odlukom povređeno njeno pravo ili zakonom zasnovan interes. Kancelarija sastavlja tužbe i zastupa stranke pred Upravnim sudom, uključujući zahteve za odlaganje izvršenja osporenog akta.</p>

        <h2>Zastupanje pred organima uprave</h2>
        <p>Osim u sporovima, advokat zastupa stranke i u redovnim upravnim postupcima — pred lokalnom samoupravom, inspekcijskim organima, katastrom nepokretnosti i drugim organima — radi ostvarivanja prava ili ispunjenja zakonskih obaveza.</p>

        <h2>Rokovi u upravnom postupku</h2>
        <p>Upravni postupak karakterišu strogi zakonski rokovi — za žalbu, za pokretanje upravnog spora, za odgovor organa. Propuštanje roka često znači gubitak prava na pravni lek, zbog čega je pravovremeno angažovanje advokata od značaja od samog prijema rešenja.</p>
      </div>
      <aside class="area-side">
        <div class="area-side-label">Konkretne usluge</div>
        <div class="area-service"><div class="area-service-h">Žalbe na rešenja</div><p class="area-service-p">Izrada žalbi protiv prvostepenih upravnih akata.</p></div>
        <div class="area-service"><div class="area-service-h">Upravni spor</div><p class="area-service-p">Tužbe i zastupanje pred Upravnim sudom.</p></div>
        <div class="area-service"><div class="area-service-h">Zastupanje pred organima uprave</div><p class="area-service-p">Lokalna samouprava, inspekcije, katastar.</p></div>
        <div class="area-service"><div class="area-service-h">Građevinski i imovinski postupci</div><p class="area-service-p">Legalizacija, upotrebne dozvole, uknjižba.</p></div>
        <div class="area-service"><div class="area-service-h">Pravni saveti</div><p class="area-service-p">Provera rokova i mogućih pravnih lekova.</p></div>
      </aside>
    </div>
  </section>
