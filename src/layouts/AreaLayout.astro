---
import BaseLayout from './BaseLayout.astro';

interface Props {
  seoTitle: string;
  seoDescription: string;
  pageTitle: string;
  deck: string;
}

const { seoTitle, seoDescription, pageTitle, deck } = Astro.props;
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <section class="page-hero">
    <div class="page-hero-inner">
      <div class="page-hero-kicker">Oblast prava</div>
      <h1 class="page-hero-h">{pageTitle}</h1>
      <p class="page-hero-deck">{deck}</p>
    </div>
  </section>

  <slot />

  <section class="kontakt-cta-section">
    <div class="wrap kontakt-cta-inner">
      <div>
        <div class="kontakt-cta-h">Imate pitanje iz ove oblasti?</div>
        <p class="kontakt-cta-p">Opišite vaš slučaj i zakažite konsultaciju. Odgovaramo u roku od jednog radnog dana.</p>
      </div>
      <a class="btn-brick" href="/kontakt">Kontaktirajte nas →</a>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .area-section { border-bottom: 3px solid var(--dark); background: var(--cream); }
  .area-grid { display: grid; grid-template-columns: 1.3fr 1fr; }
  .area-body { padding: 64px; border-right: 1px solid var(--tan); }
  .area-body p { font-size: 15px; color: var(--brown); line-height: 1.9; margin-bottom: 20px; font-weight: 300; }
  .area-body h2 { font-family: var(--serif); font-size: 26px; color: var(--dark); margin: 36px 0 16px; }
  .area-body h2:first-child { margin-top: 0; }
  .area-side { padding: 64px 48px; background: var(--cream2); }
  .area-side-label { font-size: 9px; font-weight: 800; letter-spacing: 4px; text-transform: uppercase; color: var(--gray); margin-bottom: 24px; border-bottom: 2px solid var(--dark); padding-bottom: 10px; }
  .area-service { border-bottom: 1px solid var(--tan); padding: 18px 0; }
  .area-service:last-child { border-bottom: none; }
  .area-service-h { font-family: var(--serif); font-size: 16px; color: var(--dark); margin-bottom: 6px; }
  .area-service-p { font-size: 13px; color: var(--brown); line-height: 1.6; font-weight: 300; }
  @media (max-width: 900px) { .area-grid { grid-template-columns: 1fr; } .area-body { padding: 44px 24px; border-right: none; } .area-side { padding: 44px 24px; } }

  .kontakt-cta-section { background: var(--dark); }
  .kontakt-cta-inner { padding: 56px 64px; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
  .kontakt-cta-h { font-family: var(--serif); font-size: clamp(22px, 3vw, 32px); color: var(--cream); margin-bottom: 8px; }
  .kontakt-cta-p { font-size: 14px; color: rgba(253,248,240,0.5); font-weight: 300; }
  @media (max-width: 700px) { .kontakt-cta-inner { padding: 40px 24px; } }
</style>
