---
import { getImage } from 'astro:assets';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import heroTemida from '../assets/hero-temida.webp';
import subpageHeroSource from '../assets/subpage-hero.webp';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const ogImage = await getImage({ src: heroTemida, width: 1200, height: 630, fit: 'cover', format: 'jpeg' });
const ogImageURL = new URL(ogImage.src, Astro.site);

const pageHeroBg = await getImage({ src: subpageHeroSource, width: 1600, format: 'webp', quality: 75 });

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Attorney',
  name: 'Marko A. Petrović',
  image: `${Astro.site}images/petrovic-og.jpg`,
  telephone: '+381628226111',
  email: 'mpetrovic694@gmail.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Ul. Frontovska',
    addressLocality: 'Beograd',
    postalCode: '11030',
    addressCountry: 'RS',
  },
  areaServed: ['Beograd', 'Čukarica', 'Srbija'],
  priceRange: '$$',
  knowsAbout: ['Građansko pravo', 'Upravno pravo', 'Krivično pravo'],
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
    opens: '09:00',
    closes: '17:00',
  },
  url: Astro.site,
};
---

<!DOCTYPE html>
<html lang="sr" style={`--page-hero-bg: url(${pageHeroBg.src})`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="sr_RS" />
    <meta property="og:site_name" content="Advokat Marko A. Petrović" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
    <script>
      const obs = new IntersectionObserver(
        (entries) => entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('visible'); }),
        { threshold: 0.07 }
      );
      document.querySelectorAll('.reveal').forEach((el) => obs.observe(el));
    </script>
  </body>
</html>
