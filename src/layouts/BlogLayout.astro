---
import BaseLayout from './BaseLayout.astro';

interface Props {
  seoTitle: string;
  seoDescription: string;
  tag: string;
  title: string;
  deck: string;
  datePublished: string;
}

const { seoTitle, seoDescription, tag, title, deck, datePublished } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: seoDescription,
  datePublished,
  author: { '@type': 'Person', name: 'Marko A. Petrović' },
  publisher: { '@type': 'Organization', name: 'Marko A. Petrović, advokat' },
  mainEntityOfPage: canonicalURL,
};
---

<BaseLayout title={seoTitle} description={seoDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />

  <section class="page-hero">
    <div class="page-hero-inner">
      <div class="page-hero-kicker">{tag}</div>
      <h1 class="page-hero-h">{title}</h1>
      <p class="page-hero-deck">{deck}</p>
    </div>
  </section>

  <section class="article-section">
    <div class="wrap article-wrap reveal">
      <slot />
    </div>
  </section>

  <section class="kontakt-cta-section">
    <div class="wrap kontakt-cta-inner">
      <div>
        <div class="kontakt-cta-h">Imate slično pitanje?</div>
        <p class="kontakt-cta-p">Svaki slučaj ima svoje specifičnosti. Zakažite konsultaciju za konkretan savet.</p>
      </div>
      <a class="btn-brick" href="/kontakt">Kontaktirajte nas →</a>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .article-section { border-bottom: 3px solid var(--dark); background: var(--cream); }
  .article-wrap { max-width: 760px; padding: 64px; }
  .article-wrap p { font-size: 16px; color: var(--brown); line-height: 1.9; margin-bottom: 22px; font-weight: 300; }
  .article-wrap h2 { font-family: var(--serif); font-size: 24px; color: var(--dark); margin: 36px 0 16px; }
  .article-wrap h2:first-child { margin-top: 0; }
  .article-wrap ul { margin: 0 0 22px 20px; }
  .article-wrap li { font-size: 16px; color: var(--brown); line-height: 1.85; margin-bottom: 10px; font-weight: 300; }
  .article-note { border-left: 4px solid var(--brick); padding: 14px 20px; background: var(--linen); font-size: 14px; color: var(--ink); line-height: 1.7; margin: 28px 0; }
  @media (max-width: 700px) { .article-wrap { padding: 44px 24px; } }

  .kontakt-cta-section { background: var(--dark); }
  .kontakt-cta-inner { padding: 56px 64px; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
  .kontakt-cta-h { font-family: var(--serif); font-size: clamp(22px, 3vw, 32px); color: var(--cream); margin-bottom: 8px; }
  .kontakt-cta-p { font-size: 14px; color: rgba(253,248,240,0.5); font-weight: 300; }
  @media (max-width: 700px) { .kontakt-cta-inner { padding: 40px 24px; } }
</style>
